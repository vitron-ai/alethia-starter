# dependencies (none expected — the starter is deliberately dep-free, but
# if a fork adds a build step these directories should not be committed)
node_modules/
.pnpm-store/

# OS / editor cruft
.DS_Store
.idea/
.vscode/
*.swp
Thumbs.db

# local alethia artifacts
.alethia/
*.alethia-session.json

# playwright-mcp runtime artifacts (snapshot YAML dumps + console logs)
.playwright-mcp/

# benchmark test artifacts (regenerated on every run)
benchmark/test-results/
benchmark/results.json

# python cache from `python3 -m http.server`
__pycache__/
